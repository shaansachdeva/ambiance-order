generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String   @id @default(cuid())
  name          String
  username      String   @unique
  password      String
  plainPassword String? // Stored for admin visibility
  role               String  // ADMIN, SALES, PRODUCTION, DISPATCH, ACCOUNTANT
  customPermissions  String? // JSON array of feature keys — if set, overrides role defaults
  active             Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  ordersCreated     Order[]              @relation("CreatedBy")
  statusChanges     OrderStatusLog[]     @relation("ChangedBy")
  comments          OrderComment[]       @relation("UserComments")
  attachments       OrderAttachment[]    @relation("UserAttachments")
  stockChanges      StockLog[]           @relation("UserStockChanges")
  leads             Lead[]               @relation("UserLeads")
  leadFollowUps     LeadFollowUp[]       @relation("UserLeadFollowUps")
  itemStatusChanges OrderItemStatusLog[] @relation("ItemChangedBy")
  quotations        Quotation[]          @relation("QuotationCreatedBy")
}

model Customer {
  id        String   @id @default(cuid())
  partyName String
  location  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders     Order[]
  quotations Quotation[]
}

model Order {
  id              String @id @default(cuid())
  orderId         String @unique // ORD-0001, ORD-0002, etc.
  productCategory String // BOPP_TAPE, BOPP_JUMBO, THERMAL_ROLL, BARCODE_LABEL, COMPUTER_STATIONERY (legacy single-item)
  status          String @default("ORDER_PLACED") // ORDER_PLACED, CONFIRMED, IN_PRODUCTION, RAW_MATERIAL_NA, READY_FOR_DISPATCH, DISPATCHED

  // Customer
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  // Product-specific details stored as JSON (legacy single-item)
  productDetails String // JSON string with product-specific fields

  // Common fields
  remarks          String?
  deliveryDeadline DateTime?
  challanNumber    String?
  jumboCode        String?

  // Priority
  priority String @default("NORMAL") // NORMAL, URGENT

  // Production stages (JSON: { printing: bool, cutting: bool, slitting: bool })
  productionStages String?

  // Tracking
  createdById String
  createdBy   User      @relation("CreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime? // soft delete — set when moved to recycle bin

  statusLogs  OrderStatusLog[]
  items       OrderItem[]
  comments    OrderComment[]
  attachments OrderAttachment[]
}

model OrderStatusLog {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus  String
  toStatus    String
  notes       String?
  changedById String
  changedBy   User     @relation("ChangedBy", fields: [changedById], references: [id], onDelete: Cascade)
  changedAt   DateTime @default(now())
}

model Counter {
  id    String @id @default("order_counter")
  value Int    @default(0)
}

model OrderItem {
  id               String   @id @default(cuid())
  orderId          String
  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productCategory  String
  productDetails   String // JSON
  rate             Float?
  gst              Float?
  amount           Float?
  status           String   @default("ORDER_PLACED")
  productionStages String?
  createdAt        DateTime @default(now())

  statusLogs OrderItemStatusLog[]
}

model OrderItemStatusLog {
  id          String    @id @default(cuid())
  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  fromStatus  String
  toStatus    String
  notes       String?
  changedById String
  changedBy   User      @relation("ItemChangedBy", fields: [changedById], references: [id], onDelete: Cascade)
  changedAt   DateTime  @default(now())
}

model OrderComment {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("UserComments", fields: [userId], references: [id], onDelete: Cascade)
  text      String
  createdAt DateTime @default(now())
}

model OrderAttachment {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("UserAttachments", fields: [userId], references: [id], onDelete: Cascade)
  fileName  String
  filePath  String
  fileType  String
  createdAt DateTime @default(now())
}

model RawMaterial {
  id           String     @id @default(cuid())
  name         String
  category     String // BOPP_FILM, ADHESIVE, CORE, THERMAL_PAPER, LABEL_STOCK, etc.
  unit         String // kg, rolls, pieces, meters
  currentStock Float      @default(0)
  minStock     Float      @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  logs         StockLog[]
}

model StockLog {
  id         String      @id @default(cuid())
  materialId String
  material   RawMaterial @relation(fields: [materialId], references: [id], onDelete: Cascade)
  type       String // IN, OUT
  quantity   Float
  notes      String?
  userId     String
  user       User        @relation("UserStockChanges", fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime    @default(now())
}

model Lead {
  id           String    @id @default(cuid())
  companyName  String
  location     String?   // Address / city where the company is located
  remarks      String?
  status       String    @default("NEW") // NEW, FOLLOW_UP, CONVERTED, CLOSED_LOST
  closeReason  String?
  nextFollowUp DateTime?

  // Visit proof fields
  visitPhoto    String?  // file path of photo taken at the lead's location
  visitLatitude Float?   // GPS latitude captured at time of entry
  visitLongitude Float?  // GPS longitude captured at time of entry

  salesPersonId String
  salesPerson   User   @relation("UserLeads", fields: [salesPersonId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts  LeadContact[]
  items     LeadItem[]
  followUps LeadFollowUp[]
}

model LeadContact {
  id          String  @id @default(cuid())
  leadId      String
  lead        Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  name        String
  designation String?
  phone       String?
  email       String?
  isPrimary   Boolean @default(false)
}

model LeadItem {
  id              String @id @default(cuid())
  leadId          String
  lead            Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  productCategory String
  productDetails  String // JSON
  rate            Float?
  gst             Float?
  amount          Float?
}

model LeadFollowUp {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("UserLeadFollowUps", fields: [userId], references: [id], onDelete: Cascade)
  notes     String
  createdAt DateTime @default(now())
}

// ─── Custom Product Categories ─────────────────────────────────────────────────
model CustomProductCategory {
  id        String   @id @default(cuid())
  name      String   @unique // e.g. "Kraft Tape", "Foam Tape"
  fields    String   // JSON: array of field names for data entry
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

// Admin overrides for the 5 hardcoded built-in categories (hide or rename)
model BuiltinCategoryOverride {
  key    String  @id // "BOPP_TAPE", "BOPP_JUMBO", "THERMAL_ROLL", "BARCODE_LABEL", "COMPUTER_STATIONERY"
  hidden Boolean @default(false)
  label  String? // override display name; null = use default
}

// ─── Quotations ────────────────────────────────────────────────────────────────
model QuotationCounter {
  id    String @id @default("quotation_counter")
  value Int    @default(0)
}

model Quotation {
  id           String   @id @default(cuid())
  quotationId  String   @unique // QT-0001, QT-0002, etc.
  status       String   @default("DRAFT") // DRAFT, SENT, ACCEPTED, REJECTED, EXPIRED

  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  remarks       String?
  validUntil    DateTime?
  termsAndCond  String?

  createdById  String
  createdBy    User     @relation("QuotationCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items  QuotationItem[]
}

model QuotationItem {
  id              String    @id @default(cuid())
  quotationId     String
  quotation       Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  productCategory String
  productDetails  String    // JSON
  rate            Float?
  gst             Float?
  amount          Float?
  createdAt       DateTime  @default(now())
}
